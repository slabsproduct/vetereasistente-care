<div class="card">
  <h2>👤 {{dueno.nombre}}</h2>
  <p>🪪 {{dueno.rut}}</p>
  <p>📧 {{dueno.email}}</p>
  <p>📞 {{dueno.telefono}}</p>
  <p>📍 {{dueno.direccion}}</p>
  <a href="/duenos" class="btn btn-ghost" style="margin-top:1rem;">← Volver</a>
</div>

<div class="card">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
    <h2>🐾 Mascotas</h2>
    <a href="/mascotas/nueva/{{dueno.id}}" class="btn">+ Nueva mascota</a>
  </div>

  {{#if dueno.Mascotas.length}}
    <div class="stats-grid">
      {{#each dueno.Mascotas}}
      <div class="stat-card">
        {{#if this.foto}}
          <img src="{{this.foto}}" alt="{{this.nombre}}" style="width:100%; height:150px; object-fit:cover; border-radius:12px; margin-bottom:1rem;">
        {{else}}
          <div style="width:100%; height:150px; background:rgba(240,78,35,0.1); border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:1rem; font-size:3rem;">🐾</div>
        {{/if}}
        <h3>{{this.nombre}}</h3>
        <p>{{this.especie}} - {{this.raza}}</p>
        <p>Edad: {{this.edad}} años</p>
        {{#if this.carnetVacunacion}}
          <a href="{{this.carnetVacunacion}}" target="_blank" class="btn btn-ghost" style="margin-top:0.5rem; font-size:0.85rem;">📋 Ver carnet</a>
        {{/if}}
        <div style="display:flex; gap:0.5rem; margin-top:1rem; justify-content:center;">
          <a href="/mascotas/{{this.id}}/editar" class="btn btn-ghost">✏️ Editar</a>
          <form action="/mascotas/{{this.id}}/eliminar" method="POST">
            <button type="submit" class="btn btn-ghost">🗑️ Eliminar</button>
          </form>
        </div>
      </div>
      {{/each}}
    </div>
  {{else}}
    <p>Sin mascotas registradas aún</p>
  {{/if}}
</div>