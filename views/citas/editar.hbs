<div class="card">
  <h2>✏️ Editar cita</h2>
  {{#if error}}
    <p style="color:red; margin-bottom:1rem;">{{error}}</p>
  {{/if}}
  <form action="/citas/{{cita.id}}/actualizar" method="POST" style="display:flex; flex-direction:column; gap:1rem; margin-top:1rem;">
    <select name="mascotaId" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
      <option value="">🐾 Selecciona mascota</option>
      {{#each mascotas}}
      <option value="{{this.id}}" {{#if (eq this.id ../cita.mascotaId)}}selected{{/if}}>
        🐾 {{this.nombre}} — 👤 {{this.Dueno.nombre}}
      </option>
      {{/each}}
    </select>

    <div style="display:flex; gap:1rem;">
      <input type="date" name="fechaDia" required
        style="padding:0.7rem; border-radius:8px; border:1px solid #ddd; flex:1;">
      <input type="time" name="fechaHora" required
        style="padding:0.7rem; border-radius:8px; border:1px solid #ddd; flex:1;">
    </div>

    <select name="motivo" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
      <option value="">📋 Selecciona motivo</option>
      <option value="Control rutinario" {{#if (eq cita.motivo 'Control rutinario')}}selected{{/if}}>🩺 Control rutinario</option>
      <option value="Vacunación" {{#if (eq cita.motivo 'Vacunación')}}selected{{/if}}>💉 Vacunación</option>
      <option value="Desparasitación" {{#if (eq cita.motivo 'Desparasitación')}}selected{{/if}}>🪱 Desparasitación</option>
      <option value="Consulta por enfermedad" {{#if (eq cita.motivo 'Consulta por enfermedad')}}selected{{/if}}>🤒 Consulta por enfermedad</option>
      <option value="Cirugía" {{#if (eq cita.motivo 'Cirugía')}}selected{{/if}}>🔪 Cirugía</option>
      <option value="Urgencia" {{#if (eq cita.motivo 'Urgencia')}}selected{{/if}}>🚨 Urgencia</option>
      <option value="Peluquería" {{#if (eq cita.motivo 'Peluquería')}}selected{{/if}}>✂️ Peluquería</option>
      <option value="Otro" {{#if (eq cita.motivo 'Otro')}}selected{{/if}}>📝 Otro</option>
    </select>

    <button type="submit" class="btn">Guardar cambios</button>
    <a href="/citas" class="btn btn-ghost">Cancelar</a>
  </form>
</div>