<div class="card">
  <h2>➕ Nuevo dueño</h2>
  {{#if error}}
    <p style="color:red">{{error}}</p>
  {{/if}}
  <form action="/duenos" method="POST" enctype="multipart/form-data" style="display:flex; flex-direction:column; gap:1rem; margin-top:1rem;">
    
    <h3 style="color:var(--naranja)">👤 Datos del dueño</h3>
    <input type="text" name="rut" placeholder="RUT (ej: 12.345.678-9)" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
    <input type="text" name="nombre" placeholder="Nombre completo" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
    <input type="email" name="email" placeholder="Email" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
    <input type="text" name="telefono" placeholder="Teléfono" style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
    <input type="text" name="direccion" placeholder="Dirección" style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">

    <h3 style="color:var(--naranja); margin-top:1rem;">🐾 Primera mascota</h3>
    <input type="text" name="mascotaNombre" placeholder="Nombre de la mascota" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
    <select name="mascotaEspecie" style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
      <option value="">Selecciona especie</option>
      <option value="Perro">🐶 Perro</option>
      <option value="Gato">🐱 Gato</option>
      <option value="Ave">🐦 Ave</option>
      <option value="Otro">🐾 Otro</option>
    </select>
    <input type="text" name="mascotaRaza" placeholder="Raza" style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
    <input type="number" name="mascotaEdad" placeholder="Edad en años" min="0" style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
    
    <label style="color:var(--texto-claro); font-size:0.9rem;">📷 Foto de la mascota (opcional)</label>
    <input type="file" name="mascotaFoto" accept=".jpg,.jpeg,.png" style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">

    <button type="submit" class="btn">Guardar dueño y mascota</button>
    <a href="/registro" class="btn btn-ghost">Cancelar</a>
  </form>
</div>