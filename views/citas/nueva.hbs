<div class="card">
  <h2>📅 Nueva cita</h2>
  {{#if error}}
    <p style="color:red; margin-bottom:1rem;">{{error}}</p>
  {{/if}}
  <form action="/citas" method="POST" style="display:flex; flex-direction:column; gap:1rem; margin-top:1rem;">
    
    <select name="mascotaId" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
      <option value="">🐾 Selecciona mascota</option>
      {{#each mascotas}}
      <option value="{{this.id}}">🐾 {{this.nombre}} — 👤 {{this.Dueno.nombre}}</option>
      {{/each}}
    </select>

    <div style="display:flex; gap:1rem;">
      <input type="date" name="fechaDia" required 
        style="padding:0.7rem; border-radius:8px; border:1px solid #ddd; flex:1;">
      <input type="time" name="fechaHora" required 
        style="padding:0.7rem; border-radius:8px; border:1px solid #ddd; flex:1;">
    </div>

    <select name="motivo" required style="padding:0.7rem; border-radius:8px; border:1px solid #ddd;">
      <option value="">📋 Selecciona motivo</option>
      <option value="Control rutinario">🩺 Control rutinario</option>
      <option value="Vacunación">💉 Vacunación</option>
      <option value="Desparasitación">🪱 Desparasitación</option>
      <option value="Consulta por enfermedad">🤒 Consulta por enfermedad</option>
      <option value="Cirugía">🔪 Cirugía</option>
      <option value="Urgencia">🚨 Urgencia</option>
      <option value="Peluquería">✂️ Peluquería</option>
      <option value="Otro">📝 Otro</option>
    </select>

    <button type="submit" class="btn">Guardar cita</button>
    <a href="/citas" class="btn btn-ghost">Cancelar</a>
  </form>
</div>